#include <iostream>
#include <string>

int main() {
  // Flush after every std::cout / std:cerr
  std::cout << std::unitbuf;
  std::cerr << std::unitbuf;
  bool f = false;

  while (!f) {
  std::cout << "$ ";  
  std::string input;
  std::getline(std::cin, input);
  if (input == "exit") {
    f = true;
  }
  else {
    std::cout << input << ": command not found" << std::endl;
  }
}
